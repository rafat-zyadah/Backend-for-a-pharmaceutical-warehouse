APP_NAME="Pharmacy Warehouse API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Local dev default: SQLite (zero setup). Production/Docker: switch to pgsql.
DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=pharmacy_warehouse
# DB_USERNAME=pharmacy
# DB_PASSWORD=pharmacy

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

PHARMACY_LOW_STOCK_THRESHOLD=100
PHARMACY_CURRENCY_CODE=IQD

# Default supervisor (created by: php artisan system:install)
PHARMACY_DEFAULT_SUPERVISOR_USERNAME=supervisor
PHARMACY_DEFAULT_SUPERVISOR_PASSWORD=password
PHARMACY_DEFAULT_SUPERVISOR_NAME="Supervisor Admin"
PHARMACY_DEFAULT_SUPERVISOR_PHONE=0500000001
PHARMACY_DEFAULT_SUPERVISOR_EMAIL=rafatzyadah@gmail.com

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Mail — Gmail SMTP (see README mail setup section)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=samdamas7777@gmail.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=samdamas7777@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Dev without real SMTP: set MAIL_MAILER=log
